{
    "name": "performing/wordpress",
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        }
    },
    "authors": [
        {
            "name": "Giorgio Pogliani",
            "email": "giorgiopogliani94@gmail.com"
        }
    ],
    "require": {
        "johnpbloch/wordpress": "^7.0",
        "vlucas/phpdotenv": "^5.6",
        "illuminate/support": "^13.17",
        "timber/timber": "^2.5",
        "spatie/ignition": "^1.16",
        "wp-plugin/woocommerce": "^10.8",
        "illuminate/container": "^13.17",
        "performing/twig-components": "^0.7.0"
    },
    "config": {
        "allow-plugins": {
            "johnpbloch/wordpress-core-installer": true,
            "composer/installers": true
        }
    },
    "extra": {
        "wordpress-install-dir": "public/wordpress",
        "installer-paths": {
            "public/content/plugins/{$name}/": [
                "type:wordpress-plugin"
            ],
            "public/content/mu-plugins/{$name}/": [
                "type:wordpress-muplugin"
            ],
            "public/content/themes/{$name}/": [
                "type:wordpress-theme"
            ]
        }
    },
    "repositories": [{
        "name": "wp-packages",
        "type": "composer",
        "url": "https://repo.wp-packages.org"
    }]
}
